{
  "manifest_version": 3,
  "name": "TubePulse Companion",
  "version": "1.0.0",
  "description": "Context-aware YouTube optimization widget that deep-links into the TubePulse Studio.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TubePulse Quick Panel"
  }
}
